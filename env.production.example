# ============================================================
# .env untuk docker-compose production
# Simpan file ini sebagai .env di root folder (sejajar docker-compose.yml)
# JANGAN commit file ini ke GitHub!
# ============================================================

# URL masing-masing service (ganti dengan domain kamu)
MAIN_APP_URL=https://epharma.com
AUTH_SERVICE_URL=https://auth.epharma.com
REPORT_SERVICE_URL=https://report.epharma.com

# Database
DB_DATABASE=e_pharma
DB_USERNAME=root
DB_PASSWORD=ganti_dengan_password_kuat

# Midtrans — ganti ke production key saat live
MIDTRANS_SERVER_KEY=Mid-server-xxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=Mid-client-xxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false

# Internal secret untuk komunikasi antar service
INTERNAL_SECRET=rahasia-report-service-2024
