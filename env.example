# =============================================================
# E-Pharma .env — taruh di root folder (sejajar docker-compose.yml)
# JANGAN commit file ini ke GitHub!
# =============================================================

# ─── URL DOMAIN ───────────────────────────────────────────────
MAIN_APP_URL=https://epharma.domain-kamu.com
AUTH_SERVICE_URL=https://auth.domain-kamu.com
REPORT_SERVICE_URL=https://report.domain-kamu.com

# ─── APP KEYS (generate baru, JANGAN pakai key development) ──
# Cara: php artisan key:generate --show  (jalankan di tiap folder service)
MAIN_APP_KEY=base64:
AUTH_APP_KEY=base64:
REPORT_APP_KEY=base64:

# ─── DATABASE ─────────────────────────────────────────────────
DB_PASSWORD=GANTI_PASSWORD_KUAT_MINIMAL_16_KARAKTER

# ─── MIDTRANS (pakai key PRODUCTION, bukan sandbox) ──────────
MIDTRANS_SERVER_KEY=Mid-server-
MIDTRANS_CLIENT_KEY=Mid-client-
MIDTRANS_IS_PRODUCTION=true

# ─── KOMUNIKASI ANTAR SERVICE ─────────────────────────────────
# Harus sama di distribusi_obat dan report_service
INTERNAL_SECRET=GANTI_RANDOM_STRING_32_KARAKTER

# ─── JWT (auth_service) ───────────────────────────────────────
# Cara: php artisan jwt:secret --show  (di folder auth_service)
JWT_SECRET=

# ─── EMAIL ────────────────────────────────────────────────────
MAIL_USERNAME=email-kamu@gmail.com
MAIL_PASSWORD=APP_PASSWORD_GMAIL_BARU
